<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📅 Countdown to Freedom</title>
    <style>
        /* -------- STYLING (Makes it look cool) -------- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            color: white;
            text-align: center;
            padding: 20px;
        }

        .container {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            padding: 50px 40px;
            border-radius: 30px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
            max-width: 600px;
            width: 100%;
        }

        h1 {
            font-size: 2.2rem;
            margin-bottom: 15px;
            font-weight: 700;
            background: linear-gradient(90deg, #f7971e, #ffd200);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            font-size: 1.1rem;
            opacity: 0.7;
            margin-bottom: 30px;
            letter-spacing: 1px;
        }

        .timer-box {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .time-unit {
            background: rgba(255, 255, 255, 0.08);
            padding: 15px 5px;
            border-radius: 15px;
            border-bottom: 3px solid #ffd200;
        }

        .time-unit span {
            display: block;
            font-size: 2.8rem;
            font-weight: 800;
            letter-spacing: 2px;
            color: #ffd200;
        }

        .time-unit label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            opacity: 0.6;
            margin-top: 5px;
        }

        .message-box {
            background: rgba(255, 215, 0, 0.1);
            padding: 15px;
            border-radius: 15px;
            border-left: 4px solid #ffd200;
            margin-top: 10px;
            font-size: 1.1rem;
            font-style: italic;
        }

        .motivation {
            margin-top: 20px;
            font-size: 0.9rem;
            opacity: 0.5;
        }

        /* Makes it look good on phones */
        @media (max-width: 500px) {
            .container { padding: 30px 20px; }
            .time-unit span { font-size: 2rem; }
            h1 { font-size: 1.8rem; }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>🚀 Freedom Countdown</h1>
        <p class="subtitle">Until the next big chapter</p>

        <!-- The 4 boxes for Days, Hours, Minutes, Seconds -->
        <div class="timer-box">
            <div class="time-unit">
                <span id="days">00</span>
                <label>Days</label>
            </div>
            <div class="time-unit">
                <span id="hours">00</span>
                <label>Hours</label>
            </div>
            <div class="time-unit">
                <span id="minutes">00</span>
                <label>Mins</label>
            </div>
            <div class="time-unit">
                <span id="seconds">00</span>
                <label>Secs</label>
            </div>
        </div>

        <!-- This is where the motivational quote appears -->
        <div class="message-box" id="quoteDisplay">
            "The future belongs to those who prepare for it today."
        </div>
        <p class="motivation">✨ You've got this, champ.</p>
    </div>

    <script>
        // -------- THE LOGIC (Makes it actually work) --------

        // 1. SET YOUR TARGET DATE HERE (Year, Month(0-11), Day, Hour, Minute)
        // Example: June 1st, 2026 at 12:00 PM
        const targetDate = new Date(2026, 5, 1, 12, 0, 0); 

        // 2. Array of motivational quotes
        const quotes = [
            "The future belongs to those who prepare for it today.",
            "Success is not final, failure is not fatal: it is the courage to continue that counts.",
            "You don't have to be great to start, but you have to start to be great.",
            "Believe you can and you're halfway there.",
            "It always seems impossible until it's done.",
            "Your limitation—it's only your imagination."
        ];

        // 3. Function to update the countdown
        function updateCountdown() {
            const now = new Date(); // Get current time
            const difference = targetDate - now; // Calculate milliseconds left

            // If the countdown is over...
            if (difference <= 0) {
                document.getElementById('days').textContent = '00';
                document.getElementById('hours').textContent = '00';
                document.getElementById('minutes').textContent = '00';
                document.getElementById('seconds').textContent = '00';
                document.getElementById('quoteDisplay').innerHTML = '🎉 IT\'S HERE! Go celebrate!';
                return;
            }

            // Convert milliseconds into Days, Hours, Minutes, Seconds
            const days = Math.floor(difference / (1000 * 60 * 60 * 24));
            const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((difference % (1000 * 60)) / 1000);

            // Update the HTML elements with the numbers (adding extra '0' if single digit)
            document.getElementById('days').textContent = String(days).padStart(2, '0');
            document.getElementById('hours').textContent = String(hours).padStart(2, '0');
            document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
            document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');

            // Change the motivational quote every 30 seconds
            // We use Math.floor(now.getSeconds() / 30) to switch between quotes
            const quoteIndex = Math.floor(now.getSeconds() / 30) % quotes.length;
            document.getElementById('quoteDisplay').textContent = '"' + quotes[quoteIndex] + '"';
        }

        // 4. Run the function once immediately so it doesn't start blank
        updateCountdown();

        // 5. Set an interval to update the timer every 1 second (1000 milliseconds)
        setInterval(updateCountdown, 1000);
    </script>

</body>
</html>
